# IHC Tool™ Comercial — Ejemplo de Variables de Entorno
# Copia este archivo a .env y completa con tus valores reales
# NUNCA commitees .env al repositorio

# ──────────────────────────────────────────────────────────────
# SUPABASE — Base de datos y autenticación
# ──────────────────────────────────────────────────────────────

# URL de tu proyecto Supabase (ej: https://proyecto.supabase.co)
SUPABASE_URL=

# Clave anónima para cliente (segura, visible en frontend)
SUPABASE_ANON_KEY=

# Clave de servicio para Edge Functions (SECRETO, nunca en cliente)
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# JWT Y SEGURIDAD
# ──────────────────────────────────────────────────────────────

# Secreto para firmar/verificar tokens JWT
# Obtén del dashboard de Supabase > Settings > API > JWT Secret
JWT_SECRET=

# ──────────────────────────────────────────────────────────────
# EMAIL — Resend.com para envío de licencias
# ──────────────────────────────────────────────────────────────

# API key de Resend.com para envío de emails
RESEND_API_KEY=

# ──────────────────────────────────────────────────────────────
# MONITOREO Y ERROR TRACKING
# ──────────────────────────────────────────────────────────────

# Sentry DSN para frontend (errores en navegador)
SENTRY_DSN_FRONTEND=

# Sentry DSN para backend (errores en Edge Functions/Render)
SENTRY_DSN_BACKEND=

# ──────────────────────────────────────────────────────────────
# NOTIFICACIONES
# ──────────────────────────────────────────────────────────────

# Email para alertas administrativas (renovaciones próximas, errores críticos)
ADMIN_NOTIFICATION_EMAIL=

# ──────────────────────────────────────────────────────────────
# ADMIN PANEL (Streamlit)
# ──────────────────────────────────────────────────────────────

# Dominio de autenticación para Supabase en admin panel
STREAMLIT_AUTH_DOMAIN=
